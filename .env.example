# Copy to .env and fill in. .env is git-ignored — never commit real secrets.
# Real environment variables always override values in this file.

# --- core ---
EMAIL_IN=users.csv
EMAIL_BACKEND=mock            # mock | smtp | ses
EMAIL_FROM=News <news@example.com>
EMAIL_WORKERS=200
EMAIL_RATE=500                # sends/sec = your ESP quota; 0 = unlimited
EMAIL_ATTEMPTS=5
EMAIL_CHECKPOINT=checkpoint.log
EMAIL_DLQ=dead-letter.log
EMAIL_DRYRUN=false            # true = render + count, send nothing
EMAIL_VERBOSE=false

# --- templates --- (subject = text/template, body = html/template auto-escaped)
EMAIL_SUBJECT=Hi {{.first_name}}, a note for you
EMAIL_BODY=<p>Hello {{.first_name}},</p><p>Your plan: {{.plan}}.</p>

# --- unsubscribe (REQUIRED for real bulk send: Gmail/Yahoo rules) ---
UNSUB_URL=            # e.g. https://you.com/u?e={{email}} — enables one-click (RFC 8058)
UNSUB_MAILTO=         # e.g. unsubscribe@you.com

# --- smtp backend (your VPS mail server / relay) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_TLS=true
SMTP_POOL=0                  # persistent-connection pool size; 0 = match EMAIL_WORKERS

# --- ses backend (build with -tags ses) ---
# Uses standard AWS chain; set these OR use an IAM role / shared config.
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
